# Django Settings
SECRET_KEY=your-super-secret-key-here-change-in-production-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_SSL_REDIRECT=False

# Database Configuration (local defaults)
DB_NAME=resumemaker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# For Railway Postgres, map these from service variables:
# DB_NAME=${{Postgres.PGDATABASE}}
# DB_USER=${{Postgres.PGUSER}}
# DB_PASSWORD=${{Postgres.PGPASSWORD}}
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
# Railway example:
# REDIS_URL=${{Redis.REDIS_URL}}

# AI API
OPENAI_API_KEY=your-openai-api-key
# Optional Groq-compatible setup:
# GROQ_API_KEY=your-groq-api-key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=gpt-4o-mini

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
CORS_ALLOW_ALL_ORIGINS=False
CSRF_TRUSTED_ORIGINS=http://localhost:5173
